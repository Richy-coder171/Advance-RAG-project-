GROQ_API_KEY=
OPENAI_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=zyro-rag-challenge
LANGSMITH_PROJECT=zyro-rag-challenge
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true

# Optional overrides
LLM_PROVIDER=auto
EMBEDDING_PROVIDER=auto
